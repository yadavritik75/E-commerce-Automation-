<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite  name="Suite">
	<listeners>
		<listener class-name="Amazon.Testcomponents.Listeners" />
	</listeners>

	<test thread-count="5" name="Submit Order Test">
		<groups>
			<run>
				<include name="purchase"></include>
			</run>
		</groups>
		<classes>
			<class name="Amazon.tests.submitOrderTest" />
		</classes>
	</test> <!--
	Test -->
	<test thread-count="5" name="Error Validation Test">
		<classes>
			<class name="Amazon.tests.ErrorValidationTest" />
		</classes>
	</test>
</suite> <!--
Suite -->
